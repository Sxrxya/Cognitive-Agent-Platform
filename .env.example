# ============================================
# Cognitive Agent Platform (CAP) — Environment Template
# ============================================
# COST: $0/month — All required services use free tiers
# Copy this file to .env and fill in your keys

# --- LLM: Google Gemini (FREE — 15 RPM, 1M tokens/day) ---
# Get key: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- LLM Fallback: HuggingFace (FREE inference API) ---
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# --- Embeddings (FREE — runs locally, no key needed) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Vector Database: Pinecone (FREE — 1 index, 100K vectors) ---
# Get key: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=cap-memory
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Database (SQLite — no setup needed) ---
DATABASE_URL=sqlite:///./cap_local.db

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
